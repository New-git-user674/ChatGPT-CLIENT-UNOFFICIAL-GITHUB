# Server
PORT=5000
NODE_ENV=development

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# AI Settings
DEFAULT_MODEL=gpt-4o
MAX_TOKENS=4096

# Session
SESSION_SECRET=super_secret_session_key

# Database (future use)
DATABASE_URL=postgres://user:password@localhost:5432/aiplatform

# Redis (optional)
REDIS_URL=redis://localhost:6379

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
